];

/* ═══════════════════════════════════════════════════════════
   ESTADO DO APLICATIVO
═══════════════════════════════════════════════════════════ */
let appState = {
  soundEnabled: true,
  unlockedBadges: [],
  currentNinaPhrase: 0,
};

/* ═══════════════════════════════════════════════════════════
   INICIALIZAÇÃO
═══════════════════�// Ângulo atual da rotação da ilha (em graus)
let islandRotationY = 0;

function initSpline() {
  const viewer = document.getElementById("spline-viewer");
  if (!viewer) return;

  // Previne o auto-scroll do navegador ao clicar com o botão do meio
  viewer.addEventListener("mousedown", (e) => {
    if (e.button === 1) e.preventDefault();
  });

  // Quando o Spline carrega, sinaliza que está pronto
  viewer.addEventListener("load", () => {
    splineReady = true;
    console.log("[Caderno] Cena Spline carregada! Rotação via CSS ativa.");
    const fallback = document.getElementById("spline-fallback");
    if (fallback) fallback.style.opacity = "0";
  });

  // Timeout fallback: se Spline não carregar em 8s, avisa silenciosamente
  setTimeout(() => {
    if (!splineReady) {
      console.warn("[Caderno] Spline não carregou em 8s.");
    }
  }, 8000);

  // ── ROTAÇÃO DA ILHA VIA ARRASTAR ─────────────────────────────
  // O `<spline-viewer>` web component não expõe a árvore 3D ao JS externo.
  // A solução é aplicar rotateY() no próprio elemento canvas via CSS transform.
  // O resultado visual é idêntico a girar a ilha.
  window.addEventListener("pointerdown", (e) => {
    // Não gira se o clique foi na interface (botões, modais, etc.)
    if (e.target.closest('#ui-overlay') || e.target.closest('.book-modal') || e.target.closest('.board-modal') || e.target.closest('#tutorial-overlay')) {
      return;
    }
    isDraggingIsland = true;
    lastPointerX = e.clientX;
    viewer.style.transition = "none"; // Remove transição suave durante o arraste
  }, { capture: true });

  window.addEventListener("pointermove", (e) => {
    if (!isDraggingIsland) return;
    const deltaX = e.clientX - lastPointerX;
    lastPointerX = e.clientX;
    islandRotationY += deltaX * 0.35; // 0.35° por pixel
    viewer.style.transform = `rotateY(${islandRotationY}deg)`;
  }, { capture: true });

  window.addEventListener("pointerup", () => {
    if (!isDraggingIsland) return;
    isDraggingIsland = false;
    // Adiciona momentum suave ao soltar
    viewer.style.transition = "transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)";
  }, { capture: true });
}bject = buscarIlhaProfunda(cena);
          
          // 3. PLANO C (À Prova de Falhas): O Spline apaga nomes de objetos que não têm "Code Export" ativado.
          // Como a ilha é o único objeto principal além das luzes e câmeras, pegamos o primeiro grupo estrutural!
          if (!islandObject) {
            const candidatos = cena.children.filter(c => 
              !c.name?.toLowerCase().includes('light') && 
              !c.name?.toLowerCase().includes('camera') &&
              c.type !== 'DirectionalLight' &&
              c.type !== 'PerspectiveCamera' &&
              c.type !== 'OrthographicCamera'
            );
            if (candidatos.length > 0) {
              islandObject = candidatos[0];
            }
          }
        }
      }

      if (islandObject) {
        clearInterval(buscarInterval);
        showToast(`✅ Ilha conectada!`, "success");
      } else if (tentativas >= 10) {
        clearInterval(buscarInterval);
        showToast("⚠️ O objeto 'ilha 2' definitivamente não foi encontrado.", "error", 6000);
      }
    }, 500);
  });

  // Eventos de Pointer para rotacionar a ilha (usando window com capture para evitar bloqueio do Spline)
  window.addEventListener("pointerdown", (e) => {
    // Evita rotacionar se o clique for na interface HTML por cima do 3D
    if (e.target.closest('#ui-overlay') || e.target.closest('.book-modal') || e.target.closest('.board-modal')) {
      return;
    }
    isDraggingIsland = true;
    lastPointerX = e.clientX;
    
    // Se estiver arrastando mas a ilha for null, avisa na tela
    if (!islandObject) {
      showToast("Tentando girar, mas a ilha não foi conectada.", "error");
    }
  }, { capture: true });

  window.addEventListener("pointermove", (e) => {
    if (!isDraggingIsland || !islandObject) return;
    const deltaX = e.clientX - lastPointerX;
    lastPointerX = e.clientX;
    const rotationSpeed = 0.006;
    islandObject.rotation.y += deltaX * rotationSpeed;
    
    // Força uma atualização do splineApp caso o motor esteja pausado
    if (typeof splineApp.triggerUpdate === 'function') splineApp.triggerUpdate();
  }, { capture: true });

  window.addEventListener("pointerup", () => {
    isDraggingIsland = false;
  }, { capture: true });

  // Timeout fallback: se Spline não carregar em 8s, mostra aviso silencioso
  setTimeout(() => {
    if (!splineReady) {
      console.warn("[Caderno] Spline não carregou em 8s. Verifique o arquivo .splinecode ou a URL.");
    }
  }, 8000);
}

/* ── Controle de câmera no Spline ────────────────────────── */
function setSplineCamera(cameraName) {
  if (!splineApp) return;
  try {
    // Método para trocar câmera ativa (API Spline Viewer)
    if (typeof splineApp.setCamera === "function") {
      splineApp.setCamera(cameraName);
    } else if (typeof splineApp.emitEvent === "function") {
      splineApp.emitEvent("keyUp", cameraName);
    }
  } catch (e) {
    console.warn("[Caderno] setSplineCamera:", e);
  }
}

/* ── Esconder/mostrar objeto no Spline ───────────────────── */
function hideSplineObject(objectName) {
  if (!splineApp) return;
  try {
    const obj = splineApp.findObjectByName?.(objectName);
    if (obj) obj.visible = false;
  } catch (e) {
    console.warn("[Caderno] hideSplineObject:", e);
  }
}

function showSplineObject(objectName) {
  if (!splineApp) return;
  try {
    const obj = splineApp.findObjectByName?.(objectName);
    if (obj) obj.visible = true;
  } catch (e) {
    console.warn("[Caderno] showSplineObject:", e);
  }
}

/* ── Troca de livro: fechado → aberto ────────────────────── */
function openBook() {
  // Spline: alterna objetos
  hideSplineObject("Book_Closed");
  showSplineObject("Book_Open");
  setSplineCamera("Camera_Book");

  // Fallback: abre o overlay de atividades (já gerenciado pelo botão)
}

function closeBook() {
  showSplineObject("Book_Closed");
  hideSplineObject("Book_Open");
  setSplineCamera("Camera_Home");
}

/* ═══════════════════════════════════════════════════════════
   NINA – BALÃO DE FALA
═══════════════════════════════════════════════════════════ */
function initNina() {
  const ninaText = document.getElementById("nina-text");
  if (!ninaText) return;

  // Rotaciona frases a cada 10 segundos
  setInterval(() => {
    appState.currentNinaPhrase = (appState.currentNinaPhrase + 1) % NINA_PHRASES.length;
    const bubble = document.querySelector(".speech-bubble");
    if (bubble) {
      bubble.style.opacity = "0";
      bubble.style.transform = "scale(0.9)";
      setTimeout(() => {
        ninaText.textContent = NINA_PHRASES[appState.currentNinaPhrase];
        bubble.style.opacity = "1";
        bubble.style.transform = "scale(1)";
        bubble.style.transition = "opacity 0.4s ease, transform 0.4s ease";
      }, 300);
    }
  }, 10000);
}

/* ═══════════════════════════════════════════════════════════
   FORMULÁRIO DE PALAVRA-CHAVE
═══════════════════════════════════════════════════════════ */
function initKeywordForm() {
  const form      = document.getElementById("keyword-form");
  const input     = document.getElementById("keyword-input");
  const feedback  = document.getElementById("keyword-feedback");

  if (!form) return;

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const raw     = input.value.trim();
    const keyword = normalizeKeyword(raw);

    if (!keyword) {
      showFeedback(feedback, "Digite uma palavra-chave!", "error");
      shakeElement(input);
      return;
    }

    // Verifica se a palavra-chave existe
    const badgeId = KEYWORDS_MAP[keyword];
    if (!badgeId) {
      showFeedback(feedback, "❌ Palavra-chave não encontrada. Tente de novo!", "error");
      shakeElement(form);
      return;
    }

    // Verifica se já foi desbloqueada
    if (appState.unlockedBadges.includes(badgeId)) {
      showFeedback(feedback, "✅ Você já desbloqueou esse distintivo!", "success");
      return;
    }

    // Desbloqueia o badge!
    unlockBadge(badgeId);
    input.value = "";
    showFeedback(feedback, "", "");
  });

  // Limpa feedback ao digitar
  input.addEventListener("input", () => {
    feedback.textContent = "";
    feedback.className = "keyword-feedback";
  });
}

function normalizeKeyword(str) {
  return str
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "") // remove acentos
    .replace(/[^a-z0-9]/g, "");      // só letras e números
}

function showFeedback(el, msg, type) {
  if (!el) return;
  el.textContent = msg;
  el.className = "keyword-feedback" + (type ? ` ${type}` : "");
}

/* ═══════════════════════════════════════════════════════════
   SISTEMA DE DISTINTIVOS
═══════════════════════════════════════════════════════════ */
function unlockBadge(badgeId) {
  appState.unlockedBadges.push(badgeId);
  saveState();

  const badge = BADGES_DATA.find(b => b.id === badgeId);
  if (!badge) return;

  // Atualiza UI
  renderBadgesGrid();
  updateBadgeProgress();

  // Toast comemorativo
  showToast(`🎉 Distintivo desbloqueado: ${badge.emoji} ${badge.name}!`);

  // Nina reage
  const ninaText = document.getElementById("nina-text");
  if (ninaText) {
    ninaText.textContent = `UAU! Você desbloqueou o distintivo "${badge.name}"! Parabéns! 🎉`;
  }
}

function renderBadgesGrid() {
  const grid = document.getElementById("badges-grid");
  if (!grid) return;

  const totalPages = Math.ceil(BADGES_DATA.length / BADGES_PER_PAGE);
  const startIdx = currentBadgePage * BADGES_PER_PAGE;
  const pageBadges = BADGES_DATA.slice(startIdx, startIdx + BADGES_PER_PAGE);

  const chunks = [];
  for(let i=0; i<pageBadges.length; i+=3) {
    chunks.push(pageBadges.slice(i, i+3));
  }

  grid.innerHTML = chunks.map((chunk, index) => {
    return `
      <div class="signpost-plank plank-row-${index}">
        <div class="plank-nails"><div class="nail left"></div><div class="nail right"></div></div>
        <div class="badges-row">
          ${chunk.map(badge => {
            const isUnlocked = appState.unlockedBadges.includes(badge.id);
            return `
              <div class="badge-item ${isUnlocked ? "unlocked" : "locked"}"
                   title="${isUnlocked ? badge.description : "Ainda não desbloqueado"}">
                ${isUnlocked
                  ? `<div class="badge-emoji">${badge.emoji}</div>`
                  : `<div class="badge-locked-icon">🔒</div>`
                }
                <div class="${isUnlocked ? "badge-name" : "badge-locked-name"}">
                  ${isUnlocked ? badge.name : "???"}
                </div>
              </div>
            `;
          }).join("")}
        </div>
      </div>
    `;
  }).join("");

  // Controla exibição dos botões
  const prevBtn = document.getElementById("badges-prev-btn");
  const nextBtn = document.getElementById("badges-next-btn");
  if (prevBtn) prevBtn.style.display = currentBadgePage > 0 ? "flex" : "none";
  if (nextBtn) nextBtn.style.display = currentBadgePage < totalPages - 1 ? "flex" : "none";
}

function updateBadgeProgress() {
  const count    = appState.unlockedBadges.length;
  const total    = BADGES_DATA.length;
  const pct      = total > 0 ? (count / total) * 100 : 0;

  const countEl  = document.getElementById("badges-count");
  const barEl    = document.getElementById("progress-bar");

  if (countEl) countEl.textContent = count;
  if (barEl)   barEl.style.width   = `${pct}%`;
}

